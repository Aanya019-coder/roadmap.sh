---
import Layout from '../../layouts/Layout.astro';
import { roadmaps } from '../../data/roadmaps/roadmaps';

export function getStaticPaths() {
  return roadmaps.map(r => ({
    params: { roadmapId: r.id },
    props:  { roadmap: r },
  }));
}

const { roadmapId } = Astro.params;
const { roadmap } = Astro.props;

interface Project {
  id: string;
  title: string;
  difficulty: string;
  description: string;
  links: string[];
}

let projects: Project[] = [];

try {
  // Use Vite's import.meta.glob to dynamically load the JSON files
  const dataFiles = import.meta.glob('../../data/roadmaps/*/projects.json');
  const path = `../../data/roadmaps/${roadmapId}/projects.json`;
  
  if (dataFiles[path]) {
    const jsonMod: any = await dataFiles[path]();
    projects = jsonMod.default || [];
  }
} catch (e) {
  // Graceful fallback if no JSON is defined yet
  console.error(e);
  projects = [];
}

const difficultyColors = {
  Beginner: 'badge-green',
  Intermediate: 'badge-yellow',
  Advanced: 'badge-blue',
};
---

<Layout title={`${roadmap.title} Projects | roadmap.sh`} description={`Project ideas to practice for the ${roadmap.title} roadmap.`}>
  <section style="padding:3.5rem 0 2.5rem;border-bottom:1px solid var(--color-border);">
    <div class="container">
      <nav style="display:flex;align-items:center;gap:0.5rem;font-size:0.8125rem;color:var(--color-text-muted);margin-bottom:1.5rem;">
        <a href="/" style="color:var(--color-text-muted);text-decoration:none;transition:color 0.15s" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/roadmaps" style="color:var(--color-text-muted);text-decoration:none;transition:color 0.15s" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Roadmaps</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`/roadmaps/${roadmapId}`} style="color:var(--color-text-muted);text-decoration:none;transition:color 0.15s" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{roadmap.title}</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span style="color:var(--color-text-secondary);">Projects</span>
      </nav>

      <div style="display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap;">
        <div style="width:64px;height:64px;border-radius:var(--radius-lg);background:var(--color-bg-elevated);border:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;font-size:2.25rem;flex-shrink:0;">
          {roadmap.icon}
        </div>
        <div style="flex:1;min-width:0;">
          <h1 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:0.5rem;">
            {roadmap.title} Projects
          </h1>
          <p style="color:var(--color-text-secondary);font-size:1rem;line-height:1.65;max-width:600px;margin-bottom:1.25rem;">
            Explore curated project ideas to practice your skills for the {roadmap.title} roadmap. Apply what you've learned.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="min-height: 50vh;">
    <div class="container" style="max-width: 800px;">
      {projects.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:1.5rem;">
          {projects.map((p, index) => (
            <div class="card" style="padding:1.5rem;display:flex;flex-direction:column;gap:1rem;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h2 style="font-size:1.25rem;font-weight:700;margin:0;">{index + 1}. {p.title}</h2>
                <span class={`badge ${difficultyColors[p.difficulty as keyof typeof difficultyColors] || 'badge-gray'}`}>
                  {p.difficulty}
                </span>
              </div>
              <p style="color:var(--color-text-secondary);line-height:1.6;margin:0;">
                {p.description}
              </p>
              <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:0.5rem;flex-wrap:wrap;">
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                  {p.links.map(t => (
                    <span style="font-size:0.75rem;background:#1c1c1c;padding:0.25rem 0.5rem;border-radius:4px;color:#a3a3a3;border:1px solid #262626;font-family:monospace;">
                      #{t}
                    </span>
                  ))}
                </div>
                <button class="btn btn-secondary btn-sm">
                  View Details →
                </button>
              </div>
            </div>
          ))}
        </div>
      ) : (
         <div style="text-align:center;padding:5rem 0;border:2px dashed var(--color-border);border-radius:var(--radius-xl);background:var(--color-bg-card);">
           <div style="font-size:3.5rem;margin-bottom:1rem;">📁</div>
           <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:0.75rem;">Projects Coming Soon</h2>
           <p style="color:var(--color-text-secondary);max-width:480px;margin:0 auto 1.5rem;line-height:1.65;">
             We are currently assembling a list of high-quality project ideas for the {roadmap.title} learning path. Check back soon!
           </p>
           <a href={`/roadmaps/${roadmapId}`} class="btn btn-primary">Return to Roadmap</a>
         </div>
      )}
    </div>
  </section>
</Layout>
