---
import Layout from '../layouts/Layout.astro';
import GetStartedApp from '../components/ui/GetStartedApp';

const steps = [
  { number: '01', title: 'Pick your role',      desc: 'Choose the tech role you want to work toward — frontend, backend, devops, and more.' },
  { number: '02', title: 'Follow the roadmap',  desc: 'Each roadmap is a visual guide with the exact skills and topics you need to learn.' },
  { number: '03', title: 'Track your progress', desc: 'Mark topics as Done, In Progress, or Skip. Your progress is saved to your account.' },
  { number: '04', title: 'Build real projects',  desc: 'Apply your skills with real project ideas and connect with the community.' },
];
---

<Layout title="Get Started" description="Start your developer learning journey with roadmap.sh.">
  <!-- Hero -->
  <section style="padding:3.5rem 0 2rem;text-align:center;border-bottom:1px solid var(--color-border);">
    <div class="container">
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:1rem;">
        Start your journey as a<br/><span class="gradient-text">developer</span>
      </h1>
      <p style="color:var(--color-text-secondary);font-size:1.0625rem;max-width:540px;margin:0 auto;">
        Follow our structured roadmaps to build the skills you need, step by step.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section style="padding:3rem 0;border-bottom:1px solid var(--color-border);">
    <div class="container">
      <h2 style="font-size:1.25rem;font-weight:700;letter-spacing:-0.01em;margin-bottom:1.75rem;text-align:center;">How it works</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;">
        {steps.map(s => (
          <div class="card" style="padding:1.5rem;">
            <div style="font-size:0.75rem;font-weight:700;color:var(--color-accent);letter-spacing:0.05em;margin-bottom:0.75rem;">{s.number}</div>
            <h3 style="font-weight:600;font-size:1rem;margin-bottom:0.5rem;">{s.title}</h3>
            <p style="color:var(--color-text-secondary);font-size:0.875rem;line-height:1.6;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Role picker -->
  <section class="section">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.5rem;">
        What describes you best?
      </h2>
      <GetStartedApp client:load />
    </div>
  </section>
</Layout>
