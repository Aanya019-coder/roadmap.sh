---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

let course = null;
try {
    const res = await fetch(`http://localhost:5000/api/ai/content/${id}`); // Need to add this endpoint
    if (res.ok) course = await res.json();
} catch (e) {
    console.error(e);
}

const hasData = !!course && course.type === 'course';
---

<Layout title={hasData ? course.topic : 'Course Not Found'}>
    {!hasData ? (
        <div style="text-align: center; padding: 5rem 0;">
             <h1 style="font-size: 2rem;">Course Not Found</h1>
             <a href="/ai/library" style="color: #16a34a;">Back to Library</a>
        </div>
    ) : (
        <div style="display: grid; grid-template-columns: 300px 1fr; height: calc(100vh - 60px);">
            {/* Course Sidebar */}
            <aside style="border-right: 1px solid #1f1f1f; overflow-y: auto; padding: 1.5rem; background: #0a0a0a;">
                <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 2rem;">{course.topic}</h2>
                <div style="display: flex; flexDirection: column; gap: 1rem;">
                    {course.data.modules?.map((m: any, i: number) => (
                        <div key={i}>
                            <h3 style="font-size: 0.8rem; color: #525252; textTransform: uppercase; margin-bottom: 0.75rem;">Module {i+1}: {m.title}</h3>
                            <div style="display: flex; flexDirection: column; gap: 0.5rem; padding-left: 0.5rem;">
                                {m.lessons?.map((l: any, j: number) => (
                                    <button style="text-align: left; background: none; border: none; font-size: 0.9rem; color: #a3a3a3; cursor: pointer; padding: 0.25rem 0;">
                                        {l.title}
                                    </button>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </aside>

            {/* Course Content */}
            <main style="padding: 4rem; overflow-y: auto;">
                <div style="max-width: 800px; margin: 0 auto;">
                    <span style="color: #16a34a; font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">AI Generated Course</span>
                    <h1 style="font-size: 2.5rem; font-weight: 800; margin: 1rem 0 2rem;">Select a lesson to begin</h1>
                    <div style="color: #a3a3a3; line-height: 1.8; font-size: 1.1rem;">
                        This course was generated specifically for you. Use the sidebar to navigate through the modules.
                    </div>
                </div>
            </main>
        </div>
    )}
</Layout>
