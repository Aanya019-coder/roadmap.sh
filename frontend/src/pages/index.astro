---
import Layout from '../layouts/Layout.astro';
import RoadmapCard from '../components/roadmap/RoadmapCard';
import { roadmaps, getRoadmapsByCategory } from '../data/roadmaps/roadmaps';

const roleRoadmaps         = getRoadmapsByCategory('role');
const skillRoadmaps        = getRoadmapsByCategory('skill');
const bestPractices        = getRoadmapsByCategory('best-practice');
const projectIdeas         = getRoadmapsByCategory('project');

const stats = [
  { value: '350K+',  label: 'GitHub Stars'     },
  { value: '2.8M+',  label: 'Monthly Users'    },
  { value: '45K+',   label: 'Discord Members'  },
  { value: '1,100+', label: 'Learning Paths'   },
];
---

<Layout title="Developer Roadmaps" description="Community-driven roadmaps, articles and resources for developers.">

  <!-- ══════════════════════════════════════
       HERO
       ══════════════════════════════════════ -->
  <section style="padding: 5rem 0 4rem; position: relative; overflow: hidden;">

    <!-- Ambient glow blobs -->
    <div style="position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:700px;height:400px;background:radial-gradient(ellipse,rgba(22,163,74,0.12) 0%,transparent 70%);pointer-events:none;"></div>

    <div class="container" style="text-align:center;position:relative;z-index:1;">
      <!-- Eyebrow badge -->
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(22,163,74,0.1);border:1px solid rgba(22,163,74,0.25);border-radius:999px;padding:0.3rem 0.875rem;margin-bottom:1.5rem;font-size:0.8125rem;color:var(--color-green-light);">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--color-green-light);display:inline-block;"></span>
        Open Source · Community Driven
      </div>

      <h1 class="animate-slide-up" style="font-size:clamp(2.5rem,6vw,4rem);font-weight:900;letter-spacing:-0.04em;line-height:1.1;margin-bottom:1.25rem;max-width:760px;margin-inline:auto;">
        Developer Roadmaps<br/>
        <span class="gradient-text">to guide your learning</span>
      </h1>

      <p style="font-size:clamp(1rem,2vw,1.175rem);color:var(--color-text-secondary);max-width:560px;margin:0 auto 2.5rem;line-height:1.65;">
        roadmap.sh is a community effort to create roadmaps, guides and other educational content to help developers grow in their career.
      </p>

      <!-- CTA Buttons -->
      <div style="display:flex;gap:0.875rem;justify-content:center;flex-wrap:wrap;margin-bottom:4rem;">
        <a href="/get-started" class="btn btn-primary btn-lg">
          Get Started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="https://github.com" target="_blank" class="btn btn-secondary btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          Star on GitHub
        </a>
      </div>

      <!-- Stats row -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:2rem 4rem;">
        {stats.map(s => (
          <div style="text-align:center;">
            <div class="stat-number">{s.value}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- divider -->
  <div class="container"><hr class="divider" /></div>

  <!-- ══════════════════════════════════════
       ROLE-BASED ROADMAPS
       ══════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:1.75rem;flex-wrap:wrap;">
        <div>
          <h2 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.25rem;">Role-based Roadmaps</h2>
          <p style="color:var(--color-text-secondary);font-size:0.9rem;">
            Step by step guides for specific roles in tech.
          </p>
        </div>
        <a href="/roadmaps?tab=role" class="btn btn-ghost btn-sm" style="color:var(--color-accent);">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
      <div class="grid-roadmaps">
        {roleRoadmaps.map(r => (
          <RoadmapCard roadmap={r} client:visible />
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- ══════════════════════════════════════
       SKILL-BASED ROADMAPS
       ══════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:1.75rem;flex-wrap:wrap;">
        <div>
          <h2 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.25rem;">Skill-based Roadmaps</h2>
          <p style="color:var(--color-text-secondary);font-size:0.9rem;">
            Master specific technologies and frameworks.
          </p>
        </div>
        <a href="/roadmaps?tab=skill" class="btn btn-ghost btn-sm" style="color:var(--color-accent);">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
      <div class="grid-roadmaps">
        {skillRoadmaps.map(r => (
          <RoadmapCard roadmap={r} client:visible />
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- ══════════════════════════════════════
       BEST PRACTICES
       ══════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:1.75rem;flex-wrap:wrap;">
        <div>
          <h2 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.25rem;">Best Practices</h2>
          <p style="color:var(--color-text-secondary);font-size:0.9rem;">
            Community-driven best practices on various topics.
          </p>
        </div>
        <a href="/roadmaps?tab=best-practice" class="btn btn-ghost btn-sm" style="color:var(--color-accent);">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
      <div class="grid-roadmaps">
        {bestPractices.map(r => (
          <RoadmapCard roadmap={r} client:visible />
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- ══════════════════════════════════════
       PROJECT IDEAS
       ══════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:1.75rem;flex-wrap:wrap;">
        <div>
          <h2 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.25rem;">Project Ideas</h2>
          <p style="color:var(--color-text-secondary);font-size:0.9rem;">
            Hands-on project ideas to put your skills to practice.
          </p>
        </div>
        <a href="/roadmaps?tab=project" class="btn btn-ghost btn-sm" style="color:var(--color-accent);">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
      <div class="grid-roadmaps">
        {projectIdeas.map(r => (
          <RoadmapCard roadmap={r} client:visible />
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CTA BANNER
       ══════════════════════════════════════ -->
  <section style="padding:4rem 0;">
    <div class="container">
      <div style="background:linear-gradient(135deg,var(--color-bg-card) 0%,var(--color-bg-elevated) 100%);border:1px solid var(--color-border);border-radius:20px;padding:3.5rem;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-80px;right:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(22,163,74,0.1) 0%,transparent 70%);pointer-events:none;"></div>
        <div style="position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(22,163,74,0.07) 0%,transparent 70%);pointer-events:none;"></div>
        <div style="position:relative;z-index:1;">
          <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:1rem;">
            Ready to chart your path?
          </h2>
          <p style="color:var(--color-text-secondary);font-size:1.0625rem;max-width:480px;margin:0 auto 2rem;line-height:1.65;">
            Create a free account to track your progress, bookmark resources, and build your personal learning plan.
          </p>
          <div style="display:flex;gap:0.875rem;justify-content:center;flex-wrap:wrap;">
            <a href="/signup" class="btn btn-primary btn-lg">Create Free Account</a>
            <a href="/roadmaps" class="btn btn-secondary btn-lg">Browse Roadmaps</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
