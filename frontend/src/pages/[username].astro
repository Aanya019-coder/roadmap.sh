---
import Layout from '../layouts/Layout.astro';
import OnboardingBanner from '../components/teams/OnboardingBanner';

export async function getStaticPaths() {
  // Since we are likely using SSR or hybrid mode for profiles, 
  // we might need to enable 'server' output. 
  // For now, I'll provide a dummy or assume dynamic routing works if configured.
  return [];
}

const { username } = Astro.params;

// Fetch Profile from server-side
let user = null;
let summary = [];
try {
  const userRes = await fetch(`http://localhost:5000/api/users/${username}`);
  if (userRes.ok) {
    user = await userRes.json();
    const summaryRes = await fetch(`http://localhost:5000/api/progress/summary/${user._id}`);
    if (summaryRes.ok) {
      summary = await summaryRes.json();
    }
  }
} catch (e) {
  console.error('Fetch error:', e);
}

const hasUser = !!user;
const joinDate = user?.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : '';
---

<Layout title={hasUser ? `${user.name} (@${username})` : 'User Not Found'}>
  <div class="container" style="padding: 4rem 1.5rem; max-width: 1000px; margin: 0 auto;">
    {!hasUser ? (
      <div style="text-align: center; padding: 4rem 0;">
        <h1 style="font-size: 2rem; margin-bottom: 1rem;">User Not Found</h1>
        <p style={{ color: '#a3a3a3' }}>The user you are looking for does not exist.</p>
        <a href="/" style="display: inline-block; margin-top: 1.5rem; color: #16a34a; text-decoration: none;">← Back to Home</a>
      </div>
    ) : (
      <div style="display: grid; grid-template-columns: 300px 1fr; gap: 3rem;">
        
        {/* Left Sidebar: Info */}
        <aside>
          <div style={{ textAlign: 'center', marginBottom: '2rem' }}>
             <div style={{ 
                width: 160, height: 160, borderRadius: '50%', background: '#1c1c1c', 
                border: '4px solid #262626', margin: '0 auto 1.5rem', overflow: 'hidden',
                display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '4rem'
             }}>
                {user.avatar ? <img src={user.avatar} style="width:100%;height:100%;object-fit:cover;" /> : user.name[0]}
             </div>
             <h1 style={{ fontSize: '1.5rem', fontWeight: 700, margin: '0 0 0.25rem' }}>{user.name}</h1>
             <p style={{ color: '#737373', fontSize: '0.9rem', marginBottom: '1rem' }}>@{username}</p>
             <p style={{ color: '#d4d4d4', fontSize: '0.95rem', lineHeight: 1.6, marginBottom: '1.5rem' }}>{user.bio || 'No bio yet.'}</p>
             
             <div style={{ display: 'flex', justifyContent: 'center', gap: '1rem', marginBottom: '1.5rem' }}>
                {user.githubUsername && (
                    <a href={`https://github.com/${user.githubUsername}`} target="_blank" style={{ color: '#a3a3a3', transition: 'color 0.2s' }} onMouseEnter={e => e.currentTarget.style.color='#fff'}>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" /></svg>
                    </a>
                )}
                {user.linkedinUrl && (
                    <a href={user.linkedinUrl} target="_blank" style={{ color: '#a3a3a3' }}>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" /></svg>
                    </a>
                )}
             </div>

             <div style={{ borderTop: '1px solid #262626', paddingTop: '1.5rem', textAlign: 'left', fontSize: '0.85rem', color: '#737373' }}>
                <p style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.5rem' }}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    Joined {joinDate}
                </p>
             </div>
          </div>
        </aside>

        {/* Right Content: Roadmaps & Activity */}
        <main>
          <OnboardingBanner client:load />

          <section style={{ marginBottom: '3rem' }}>
            <h2 style={{ fontSize: '1.25rem', fontWeight: 600, marginBottom: '1.5rem' }}>Roadmaps Progress</h2>
            {summary.length === 0 ? (
                <div style={{ padding: '2rem', background: '#111', borderRadius: '12px', border: '1px solid #262626', textAlign: 'center', color: '#737373' }}>
                    No roadmaps started yet.
                </div>
            ) : (
                <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
                    {summary.map(s => {
                        const progress = s.totalCount > 0 ? Math.round((s.doneCount / 67) * 100) : 0; // 67 is approx frontend total, should use real total
                        return (
                            <div key={s._id} style={{ padding: '1.25rem', background: '#111', borderRadius: '12px', border: '1px solid #262626' }}>
                                <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '0.75rem' }}>
                                    <span style={{ fontWeight: 600, color: '#fff', textTransform: 'capitalize' }}>{s._id}</span>
                                    <span style={{ fontSize: '0.85rem', color: '#16a34a' }}>{progress}%</span>
                                </div>
                                <div style={{ height: '8px', background: '#1c1c1c', borderRadius: '100px', overflow: 'hidden' }}>
                                    <div style={{ height: '100%', width: `${progress}%`, background: '#16a34a', borderRadius: '100px' }} />
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}
          </section>

          <section>
            <h2 style={{ fontSize: '1.25rem', fontWeight: 600, marginBottom: '1.5rem' }}>Activity Graph</h2>
            <div style={{ padding: '1.5rem', background: '#111', borderRadius: '12px', border: '1px solid #262626' }}>
                {/* Mockup of contribution graph */}
                <div style={{ display: 'flex', gap: '3px', flexWrap: 'wrap' }}>
                    {Array.from({ length: 154 }).map((_, i) => (
                        <div key={i} style={{ 
                            width: 10, height: 10, borderRadius: '2px', 
                            background: Math.random() > 0.8 ? '#16a34a' : Math.random() > 0.95 ? '#22c55e' : '#1c1c1c' 
                        }} />
                    ))}
                </div>
                <p style={{ marginTop: '1rem', fontSize: '0.75rem', color: '#525252' }}>Activity data is simulated for mockup purposes.</p>
            </div>
          </section>
        </main>

      </div>
    )}
  </div>
</Layout>
