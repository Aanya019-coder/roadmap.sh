---
import Layout from '../layouts/Layout.astro';
import RoadmapsApp from '../components/roadmap/RoadmapsApp';
---

<Layout
  title="Developer Roadmaps"
  description="Browse all community-driven developer roadmaps, best practices, and learning guides on roadmap.sh."
>
  <!-- Page Header -->
  <section style="padding:3.5rem 0 2.5rem;border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;">
        <div>
          <h1 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:0.5rem;">
            Developer Roadmaps
          </h1>
          <p style="color:var(--color-text-secondary);font-size:1rem;max-width:500px;line-height:1.6;">
            Community-driven roadmaps, best practices, and guides for developers. Browse all {22} paths below.
          </p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <a href="/get-started" class="btn btn-primary">
            Where to start?
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmaps listing app -->
  <section class="section">
    <div class="container">
      <RoadmapsApp client:load />
    </div>
  </section>
</Layout>
